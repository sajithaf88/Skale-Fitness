@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Login - Skale Fitness</title>

    <style>
        body {
            background: linear-gradient(to right, #FFC107, #fff);
            font-family: Arial;
        }

        .login-box {
            width: 350px;
            background: white;
            padding: 30px;
            margin: 120px auto;
            box-shadow: 0 0 20px rgba(0,0,0,0.2);
            border-radius: 10px;
        }

        h2 {
            text-align: center;
        }

        input {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
        }

        button {
            width: 100%;
            padding: 12px;
            background: #FFC107;
            border: none;
            font-weight: bold;
        }

        .error {
            color: red;
            text-align: center;
        }
    </style>
</head>

<body>

    <div class="login-box">

        <h2>Skale Fitness Login</h2>

        @if (ViewBag.Error != null)
        {
            <p class="error">@ViewBag.Error</p>
        }

        <form method="post">
            <input name="Username" placeholder="Username" required />
            <input name="Password" type="password" placeholder="Password" required />
            <button type="submit">LOGIN</button>
        </form>

        <a asp-action="Register">Create new account</a>

    </div>

</body>
</html>