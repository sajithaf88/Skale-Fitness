@model Member

<style>
    .card {
        background: #f9fafb;
        padding: 25px;
        width: 420px;
        border-radius: 10px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    }

    p {
        margin: 6px 0;
        font-size: 15px;
    }

    .btn-back {
        background: #6b7280;
        color: white;
        padding: 8px 18px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        margin-top: 15px;
    }

        .btn-back:hover {
            background: #4b5563;
        }
</style>

<h2>Member Details</h2>

<div class="card">
    <p><b>Name:</b> @Model.Name</p>
    <p><b>Email:</b> @Model.Email</p>
    <p><b>Phone:</b> @Model.Phone</p>
    <p><b>Gender:</b> @Model.Gender</p>
    <p><b>Status:</b> @Model.Status</p>

    <br />

    <button type="button" class="btn-back" onclick="history.back()">Back</button>
</div>
