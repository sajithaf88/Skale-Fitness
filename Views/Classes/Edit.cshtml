@model SkaleFitnessMVC.Models.FitnessClass

<style>
    .form-box {
        max-width: 450px;
        background: #f9fafb;
        padding: 25px;
        border-radius: 10px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    }

    label {
        font-weight: 600;
        display: block;
        margin-top: 10px;
    }

    input, select {
        width: 100%;
        padding: 8px;
        margin-top: 4px;
        border: 1px solid #ccc;
        border-radius: 6px;
    }

    .btn-update {
        background: #2563eb;
        color: white;
        padding: 8px 18px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        margin-top: 15px;
    }

    .btn-back {
        background: #6b7280;
        color: white;
        padding: 8px 18px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        margin-left: 10px;
    }
</style>

<h2>Edit Fitness Class</h2>

<div class="form-box">
    <form method="post">
        <input type="hidden" asp-for="FitnessClassId" />

        <label>Class Name</label>
        <input asp-for="ClassName" required />

        <label>Trainer</label>
        <select asp-for="TrainerId" required>
            @foreach (var t in ViewBag.Trainers)
            {
                <option value="@t.TrainerId">@t.Name</option>
            }
        </select>

        <button type="submit" class="btn-update">Update</button>
        <button type="button" class="btn-back" onclick="history.back()">Back</button>
    </form>
</div>
