@model SkaleFitnessMVC.Models.FitnessClass

<style>
    .card {
        background: #f9fafb;
        padding: 25px;
        width: 420px;
        border-radius: 10px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    }

    p {
        margin: 6px 0;
        font-size: 15px;
    }

    .btn-back {
        background: #6b7280;
        color: white;
        padding: 8px 18px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        margin-top: 15px;
    }
</style>

<h2>Class Details</h2>

<div class="card">
    <p><b>Class ID:</b> @Model.FitnessClassId</p>
    <p><b>Class Name:</b> @Model.ClassName</p>
    <p><b>Trainer ID:</b> @Model.TrainerId</p>

    <button type="button" class="btn-back" onclick="history.back()">Back</button>
</div>
