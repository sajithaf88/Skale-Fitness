@model IEnumerable<SkaleFitnessMVC.Models.Trainer>

@using Microsoft.AspNetCore.Http
@{
    var role = Context.Session.GetString("Role");
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    th, td {
        padding: 12px;
        border-bottom: 1px solid #e5e7eb;
        vertical-align: middle;
    }

    th {
        background: #f3f4f6;
        text-align: left;
        font-weight: 600;
    }

    tr:hover {
        background: #f9fafb;
    }

    .btn {
        padding: 6px 12px;
        border-radius: 6px;
        color: white;
        text-decoration: none;
        font-size: 14px;
        margin-right: 4px;
        display: inline-block;
    }

    .add {
        background: #22c55e;
    }

    .view {
        background: #374151;
    }

    .edit {
        background: #2563eb;
    }

    .del {
        background: #dc2626;
    }

    .btn:hover {
        opacity: 0.9;
    }

    .photo {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #e5e7eb;
    }

    .no-photo {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        background: #e5e7eb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        color: #6b7280;
    }
</style>

<h2>Trainers</h2>

<div class="page-header">
    <span></span>

    
    @if (role == "Admin")
    {
        <a class="btn add" asp-action="Create">+ Add Trainer</a>
    }
    

</div>

<table>
    <tr>
        <th>Photo</th>
        <th>Name</th>
        <th>Specialization</th>
        <th>Phone</th>
        <th>Actions</th>
    </tr>

    
    @foreach (var t in Model)
    {
        <tr>
            <td>
                @if (!string.IsNullOrEmpty(t.ImagePath))
                {
                    <img src="~/images/trainers/@t.ImagePath" class="photo" />
                }
                else
                {
                    <div class="no-photo">No Photo</div>
                }
            </td>

            <td>@t.Name</td>
            <td>@t.Specialization</td>
            <td>@t.Phone</td>

            <td>
                <a class="btn view"
                   asp-action="Details"
                   asp-route-id="@t.TrainerId">
                    View
                </a>

                @if (role == "Admin")
                {
                    <a class="btn edit"
                       asp-action="Edit"
                       asp-route-id="@t.TrainerId">
                        Edit
                    </a>

                    <a class="btn del"
                       asp-action="Delete"
                       asp-route-id="@t.TrainerId">
                        Delete
                    </a>
                }
            </td>
        </tr>
    }
    

</table>
