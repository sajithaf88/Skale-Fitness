@model Trainer

<style>
    .card {
        background: #f9fafb;
        padding: 20px;
        width: 420px;
        border-radius: 10px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    }

    .photo {
        border-radius: 50%;
        border: 2px solid #e5e7eb;
        margin-bottom: 15px;
    }

    p {
        margin: 6px 0;
        font-size: 15px;
    }

    .btn-back {
        background: #6b7280;
        color: white;
        padding: 8px 16px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
    }

        .btn-back:hover {
            background: #4b5563;
        }
</style>

<h2>Trainer Details</h2>

<div class="card">
    @if (!string.IsNullOrEmpty(Model.ImagePath))
    {
        <img src="~/images/trainers/@Model.ImagePath" width="120" height="120" class="photo" />
    }

    <p><b>Name:</b> @Model.Name</p>
    <p><b>Specialization:</b> @Model.Specialization</p>
    <p><b>Phone:</b> @Model.Phone</p>
    <p><b>Status:</b> @Model.Status</p>

    <br />

    <button type="button" class="btn-back" onclick="history.back()">Back</button>
</div>
