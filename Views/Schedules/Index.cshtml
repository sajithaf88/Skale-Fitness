@model IEnumerable<SkaleFitnessMVC.Models.Schedule>
<style>
    h2 {
        margin-bottom: 15px;
    }

    .add-btn {
        display: inline-block;
        margin-bottom: 15px;
        padding: 8px 15px;
        background: #FFC107;
        color: black;
        text-decoration: none;
        font-weight: bold;
        border-radius: 5px;
    }

    table {
        width: 80%;
        border-collapse: collapse;
        background: white;
    }

    th {
        background: #111;
        color: white;
        padding: 10px;
    }

    td {
        padding: 8px;
        border: 1px solid #ccc;
        text-align: center;
    }

    .action-btn {
        padding: 5px 10px;
        text-decoration: none;
        font-size: 14px;
        border-radius: 4px;
        margin: 2px;
        display: inline-block;
    }

    .edit {
        background: #28a745;
        color: white;
    }

    .delete {
        background: #dc3545;
        color: white;
    }

        .delete:hover {
            background: darkred;
        }
</style>

<h2>Class Schedules</h2>

<a href="/Schedules/Create">Add New Schedule</a>

<table border="1" cellpadding="5">
    <tr>
        <th>Schedule ID</th>
        <th>Class ID</th>
        <th>Date</th>
        <th>Start Time</th>
        <th>End Time</th>
    </tr>

    @foreach (var s in Model)
    {
        <tr>
            <td>@s.ScheduleId</td>
            <td>@s.FitnessClassId</td>
            <td>@s.Date.ToShortDateString()</td>
            <td>@s.StartTime</td>
            <td>@s.EndTime</td>
        </tr>
    }
</table>

<br />
<a href="/Home/Dashboard">Back to Dashboard</a>
