@model SkaleFitnessMVC.Models.Attendance

<style>
    .card {
        max-width: 450px;
        background: #f9fafb;
        padding: 25px;
        border-radius: 10px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    }

    p {
        margin: 6px 0;
        font-size: 15px;
    }

    .btn-back {
        background: #6b7280;
        color: white;
        padding: 8px 18px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        margin-top: 15px;
    }

        .btn-back:hover {
            background: #4b5563;
        }
</style>

<h2>Attendance Details</h2>

<div class="card">
    <p><b>Attendance ID:</b> @Model.AttendanceId</p>
    <p><b>Member ID:</b> @Model.MemberId</p>
    <p><b>Class ID:</b> @Model.FitnessClassId</p>
    <p><b>Date:</b> @Model.AttendanceDate.ToShortDateString()</p>
    <p><b>Status:</b> @Model.Status</p>

    <button type="button" class="btn-back" onclick="history.back()">Back</button>
</div>
