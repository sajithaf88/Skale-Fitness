@model SkaleFitnessMVC.Models.Attendance

<style>
    .form-box {
        max-width: 500px;
        background: #f9fafb;
        padding: 25px;
        border-radius: 10px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    }

    label {
        font-weight: 600;
        display: block;
        margin-top: 10px;
    }

    select, input {
        width: 100%;
        padding: 8px;
        margin-top: 4px;
        border: 1px solid #ccc;
        border-radius: 6px;
    }

    .btn-save {
        background: #22c55e;
        color: white;
        padding: 8px 18px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        margin-top: 15px;
    }

    .btn-back {
        background: #6b7280;
        color: white;
        padding: 8px 18px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        margin-left: 10px;
    }

    .btn-save:hover {
        background: #16a34a;
    }

    .btn-back:hover {
        background: #4b5563;
    }
</style>

<h2>Add Attendance</h2>

<div class="form-box">
    <form method="post">

        <label>Member</label>
        <select asp-for="MemberId" required>
            <option value="">-- Select Member --</option>
            @foreach (var m in ViewBag.Members)
            {
                <option value="@m.MemberId">@m.Name</option>
            }
        </select>

        <label>Class</label>
        <select asp-for="FitnessClassId" required>
            <option value="">-- Select Class --</option>
            @foreach (var c in ViewBag.Classes)
            {
                <option value="@c.FitnessClassId">@c.ClassName</option>
            }
        </select>

        <label>Date</label>
        <input asp-for="AttendanceDate" type="date" required />

        <label>Status</label>
        <select asp-for="Status">
            <option value="Present">Present</option>
            <option value="Absent">Absent</option>
        </select>

        <br />

        <button type="submit" class="btn-save">Save</button>
        <button type="button" class="btn-back" onclick="history.back()">Back</button>

    </form>
</div>
