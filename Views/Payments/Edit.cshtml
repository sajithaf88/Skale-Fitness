@model SkaleFitnessMVC.Models.Payment

<style>
    .form-box {
        max-width: 500px;
        background: #f9fafb;
        padding: 25px;
        border-radius: 10px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    }

    label {
        font-weight: 600;
        display: block;
        margin-top: 10px;
    }

    input, select {
        width: 100%;
        padding: 8px;
        margin-top: 4px;
        border: 1px solid #ccc;
        border-radius: 6px;
    }

    .btn-update {
        background: #2563eb;
        color: white;
        padding: 8px 18px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        margin-top: 15px;
    }

    .btn-back {
        background: #6b7280;
        color: white;
        padding: 8px 18px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        margin-left: 10px;
    }

    .btn-update:hover {
        background: #1e40af;
    }

    .btn-back:hover {
        background: #4b5563;
    }
</style>

<h2>Edit Payment</h2>

<div class="form-box">
    <form method="post">
        <input type="hidden" asp-for="PaymentId" />

        <label>Member</label>
        <select asp-for="MemberId" required>
            @foreach (var m in ViewBag.Members)
            {
                <option value="@m.MemberId"
                        selected="@(m.MemberId == Model.MemberId)">
                    @m.Name
                </option>
            }
        </select>

        <label>Amount</label>
        <input asp-for="Amount" type="number" step="0.01" required />

        <label>Payment Date</label>
        <input asp-for="PaymentDate" type="date" required />

        <label>Payment Method</label>
        <select asp-for="Method" required>
            <option value="Cash">Cash</option>
            <option value="Card">Card</option>
            <option value="UPI">UPI</option>
            <option value="Online">Online</option>
        </select>

        <br />

        <button type="submit" class="btn-update">Update</button>
        <button type="button" class="btn-back" onclick="history.back()">Back</button>
    </form>
</div>
